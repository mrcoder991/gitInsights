# gitInsights — frontend environment (Vite)
# All keys must be prefixed VITE_ to be exposed to the client. See spec §9.
# Copy this file to `.env.local` for local dev and fill in the dev OAuth App values.

# Public OAuth App client ID (from GitHub OAuth App settings).
# Dev: register an OAuth App with callback http://localhost:5173/callback
# Prod: register a separate OAuth App with callback https://<gh-user>.github.io/gitInsights/callback
VITE_GITHUB_CLIENT_ID=

# Full URL to the Vercel token-exchange function (api/authenticate.ts).
# e.g. https://gitinsights-proxy.vercel.app/api/authenticate
VITE_PROXY_URL=

# The GitHub Pages callback URL registered with the OAuth App.
# Dev: http://localhost:5173/callback
# Prod: https://<gh-user>.github.io/gitInsights/callback
VITE_OAUTH_REDIRECT_URI=

# Canonical site origin (no trailing slash). Used for Open Graph / Twitter
# absolute URLs in index.html. Dev: omit or use http://localhost:5173.
# Prod build (CI): set to https://<gh-user>.github.io/<repo-name>
VITE_CANONICAL_ORIGIN=

# ---------------------------------------------------------------------------
# Vercel proxy environment (server-side only — NOT prefixed VITE_).
# These are configured in the Vercel project dashboard, not in this file.
# Listed here so a self-hoster knows what the proxy expects:
#
#   GITHUB_CLIENT_ID       # same OAuth App as VITE_GITHUB_CLIENT_ID
#   GITHUB_CLIENT_SECRET   # the OAuth App's client secret (NEVER commit)
#   ALLOWED_ORIGIN         # exact origin allowed by CORS, e.g.
#                          # https://<gh-user>.github.io   (prod)
#                          # http://localhost:5173         (dev)
# ---------------------------------------------------------------------------
