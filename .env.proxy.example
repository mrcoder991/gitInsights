# gitInsights — Vercel proxy local-dev environment (consumed by scripts/dev-proxy.ts).
# Copy to `.env.proxy.local` (gitignored) and fill with your dev OAuth App values.
# These are the SAME keys Vercel reads for the deployed function — just local.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ALLOWED_ORIGIN=http://localhost:5173
