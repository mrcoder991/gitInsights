{
  "name": "gitinsights",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "dev:proxy": "tsx --env-file=.env.proxy.local scripts/dev-proxy.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist -t",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "size": "npm run build && size-limit",
    "smoke:vercel-proxy": "tsx scripts/smoke-vercel-proxy.ts",
    "fetch-holidays": "tsx scripts/fetch-holidays.ts",
    "render-brand-assets": "tsx scripts/render-brand-assets.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vercel/node": "^5.7.11",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.10",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.21",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mantine/charts": "^7.17.8",
    "@mantine/core": "^7.17.8",
    "@mantine/dates": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "@primer/octicons-react": "^19.24.1",
    "@primer/primitives": "^10.7.0",
    "@tanstack/query-async-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "comlink": "^4.4.2",
    "dayjs": "^1.11.20",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "styled-components": "^6.4.0",
    "zustand": "^5.0.12"
  }
}
